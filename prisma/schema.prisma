// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  SHOP_OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PartCategory {
  WHEELS
  BODY_KIT
  EXHAUST
  SUSPENSION
  WRAP
  LIGHTS
  INTERIOR
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  name          String?
  avatarUrl     String?
  phone         String?
  role          Role          @default(CUSTOMER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  vehicles      Vehicle[]     // Digital twin garage
  bookings      Booking[]     // Client modifications bookings
  posts         Post[]        // Community posts
  likes         Like[]        // Likes on builds
  comments      Comment[]     // Comments on builds
  conversations Message[]     // Chat support logs
  shop          Shop?         // Link to shop profile if role is SHOP_OWNER
}

model Shop {
  id              String        @id @default(uuid())
  ownerId         String        @unique
  owner           User          @relation(fields: [ownerId], references: [id])
  name            String
  city            String
  address         String
  whatsapp        String?
  instagram       String?
  experienceYears Int
  verified        Boolean       @default(false)
  priceTier       String        @default("mid") // economy, mid, premium
  warrantyPeriod  String?
  logoUrl         String?
  bannerUrl       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  specializations ShopSpecialty[]
  packages        Package[]
  bookings        Booking[]
  reviews         Review[]
  completedBuilds CompletedBuild[]
}

model ShopSpecialty {
  id      String   @id @default(uuid())
  shopId  String
  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name    String   // Performance, Wraps, Paint, etc.
}

model Package {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String
  price       Float
  duration    String   // e.g. "3 Days"
}

model CompletedBuild {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title       String
  description String
  beforeImg   String
  afterImg    String
  createdAt   DateTime @default(now())
}

model Vehicle {
  id                 String           @id @default(uuid())
  ownerId            String
  owner              User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  make               String           // e.g. "Porsche"
  model              String           // e.g. "911 GT3"
  generation         String?          // e.g. "992"
  color              String
  vin                String?          @unique
  registrationNumber String?          @unique
  thumbnailUrl       String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  bookings           Booking[]
  historyLogs        ServiceLog[]
}

model ServiceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  title       String   // e.g. "Satin Green Wrap Fitted"
  description String
  date        DateTime
  invoiceUrl  String?
}

model Booking {
  id             String        @id @default(uuid())
  customerId     String
  customer       User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vehicleId      String
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  status         BookingStatus @default(PENDING)
  scheduledDate  DateTime
  scheduledTime  String
  advancePaid    Float         @default(5000)
  totalCost      Float?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  transactions   Transaction[]
}

model Part {
  id             String       @id @default(uuid())
  name           String
  brand          String
  category       PartCategory
  price          Float
  imageUrl       String?
  description    String?
  compatibility  String[]     // list of compatible make/model strings
  stockCount     Int          @default(0)
  createdAt      DateTime     @default(now())
}

model Post {
  id        String    @id @default(uuid())
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  carModel  String
  text      String
  imageUrl  String?
  likes     Like[]
  comments  Comment[]
  createdAt DateTime  @default(now())
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount    Float
  platformCommission Float
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderName  String
  text        String
  createdAt   DateTime @default(now())
}
